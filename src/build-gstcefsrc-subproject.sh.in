#!/bin/sh

set -eu

download_stamp_path="$1"
stamp_path="$2"
src_dir='@gstcefsrc_source_dir@'
build_dir='@gstcefsrc_build_dir@'
stage_dir='@gstcefsrc_stage_dir@'
cef_root_dir='@gstcefsrc_cef_root_dir@'

if [ ! -f "$download_stamp_path" ]; then
    echo "gstcefsrc CEF download stamp not found: $download_stamp_path" >&2
    exit 1
fi

if [ ! -d "$cef_root_dir" ]; then
    echo "gstcefsrc CEF root directory not found: $cef_root_dir" >&2
    exit 1
fi

echo "==> Configuring gstcefsrc CMake project"
rm -rf "$build_dir"
mkdir -p "$build_dir" "$stage_dir"

cmake -S "$src_dir" -B "$build_dir" \
    -DCMAKE_BUILD_TYPE=Release \
    -DCEF_ROOT="$cef_root_dir" \
    -DCMAKE_INSTALL_PREFIX="$stage_dir"

echo "==> Building gstcefsrc native bridge"
cmake --build "$build_dir" --config Release --verbose

echo "==> Collecting gstcefsrc build artifacts"
cmake --install "$build_dir" --config Release

touch "$stamp_path"
