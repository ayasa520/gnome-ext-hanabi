#: src/prefs/rows.js:163
msgid "Pause on Maximize or Fullscreen"
msgstr "Pausa vid Maximering eller Helskärm"

#: src/prefs/rows.js:164
msgid "Pause playback when there is maximized or fullscreen window"
msgstr "Pausa uppspelning när det är en maximerad eller helskärmsruta"

#: src/prefs/rows.js:165
msgid ""
"\n"
"    <b>Never</b>: Disable this feature.\n"
"    <b>Any Monitor</b>: Pause playback when there is maximized or fullscreen "
"window on any monitor.\n"
"    <b>All Monitors</b>: Pause playback when there are maximized or "
"fullscreen windows on all monitors.\n"
"    "
msgstr ""
"\n"
"    <b>Aldrig</b>: Disable this feature.\n"
"    <b>Vilken bildskärm som helst</b>: Pausa uppspelning när det är en "
"maximiserad eller helskärmsruta på vilken bildskärm som helst.\n"
"    <b>Alla bildskärmar</b>: Pausa uppspelning när det är en maximiserad "
"eller helskärmsruta på alla bildskärmar.\n"
"    "

#: src/prefs/rows.js:172 src/prefs/rows.js:203
msgid "Never"
msgstr "Aldrig"

#: src/prefs/rows.js:173
msgid "Any Monitor"
msgstr "Vilken bildskärm som helst"

#: src/prefs/rows.js:174
msgid "All Monitors"
msgstr "Alla bildskärmar"

#: src/prefs/rows.js:194
msgid "Pause on Battery"
msgstr "Pausa på batteri"

#: src/prefs/rows.js:195
msgid "Pause playback when the device is on battery or the battery is low"
msgstr ""
"Pausa uppspelning när enheten är på batteri eller när batteriet är lågt"

#: src/prefs/rows.js:196
msgid ""
"\n"
"    <b>Never</b>: Disable this feature.\n"
"    <b>Low Battery</b>: Pause playback when the device is on low battery "
"(below the threshold).\n"
"    <b>Always</b>: Pause playback when the device is on battery.\n"
"    "
msgstr ""
"\n"
"    <b>Aldrig</b>: Avaktivera denna funktion.\n"
"    <b>Låg batterinivå</b>: Pausa uppspelning när enheten har lågt på "
"batteri (Under tröskeln).\n"
"    <b>Alltid</b>: Pausa uppspelning när enheten går på batteri.\n"
"    "

#: src/prefs/rows.js:204
msgid "Low Battery"
msgstr "Låg batterinivå"

#: src/prefs/rows.js:205
msgid "Always"
msgstr "Alltid"

#: src/prefs/rows.js:225
msgid "Change Wallpaper Mode"
msgstr "Ändra bakgrundsläge"

#: src/prefs/rows.js:226
msgid "Control how to change wallpapers automatically"
msgstr "Kontrollera hur man ändrar bakgrund automatiskt"

#: src/prefs/rows.js:227
msgid ""
"\n"
"    <b>Sequential:</b> Preserve the directory sequence (descending order).\n"
"    <b>Inverse Sequential:</b> Retrieve wallpapers in the opposite sequence "
"(ascending order).\n"
"    <b>Random:</b> Randomly select wallpapers from the directory.\n"
"    "
msgstr ""
"\n"
"    <b>Sekventiell:</b> Behåll mappens sekvens(Fallande ordning).\n"
"    <b>Invers Sekvens:</b> Hämta bakgrunder i motsatt sekvens (Stigande "
"ordning).\n"
"    <b>Slumpmässig:</b> Slumpmässigt välj bakgrunden från mappen.\n"
"    "

#: src/prefs/rows.js:234
msgid "Sequential"
msgstr "Sekventiell"

#: src/prefs/rows.js:235
msgid "Inverse Sequential"
msgstr "Invers sekvens"

#: src/prefs/rows.js:236
msgid "Random"
msgstr "Slumpmässigt"

