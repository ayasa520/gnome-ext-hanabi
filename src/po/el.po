#: src/prefs/rows.js:122
msgid ""
"\n"
"        <b>WPE WebKit</b>: The default backend for web wallpapers.\n"
"        <b>CEF (gstcefsrc)</b>: Experimental Chromium-based backend using "
"GStreamer.\n"
"        "
msgstr ""
"\n"
"        <b>WPE WebKit</b>: Το προεπιλεγμένο backend για ταπετσαρίες ιστού.\n"
"        <b>CEF (gstcefsrc)</b>: Πειραματικό backend βασισμένο στο Chromium που χρησιμοποιεί GStreamer.\n"
"        "

#: src/prefs/rows.js:126
msgid "<b>WPE WebKit</b>: The default backend for web wallpapers."
msgstr "<b>WPE WebKit</b>: Το προεπιλεγμένο backend για ταπετσαρίες ιστού."

#: src/prefs/rows.js:163
msgid "Pause on Maximize or Fullscreen"
msgstr "Παύση σε μεγιστοποίηση ή πλήρη οθόνη"

#: src/prefs/rows.js:164
msgid "Pause playback when there is maximized or fullscreen window"
msgstr ""
"Παύση αναπαραγωγής όταν υπάρχει μεγιστοποιημένο παράθυρο ή παράθυρο πλήρους "
"οθόνης"

#: src/prefs/rows.js:165
msgid ""
"\n"
"    <b>Never</b>: Disable this feature.\n"
"    <b>Any Monitor</b>: Pause playback when there is maximized or fullscreen "
"window on any monitor.\n"
"    <b>All Monitors</b>: Pause playback when there are maximized or "
"fullscreen windows on all monitors.\n"
"    "
msgstr ""
"\n"
"    <b>Ποτέ</b>: Απενεργοποίηση αυτής της λειτουργίας.\n"
"    <b>Οποιαδήποτε οθόνη</b>: Παύση αναπαραγωγής όταν υπάρχει μεγιστοποιημένο παράθυρο ή παράθυρο πλήρους οθόνης σε οποιαδήποτε οθόνη.\n"
"    <b>Όλες οι οθόνες</b>: Παύση αναπαραγωγής όταν υπάρχουν μεγιστοποιημένα παράθυρα ή παράθυρα πλήρους οθόνης σε όλες τις οθόνες.\n"
"    "

#: src/prefs/rows.js:172 src/prefs/rows.js:203
msgid "Never"
msgstr "Ποτέ"

#: src/prefs/rows.js:173
msgid "Any Monitor"
msgstr "Οποιαδήποτε Οθόνη"

#: src/prefs/rows.js:174
msgid "All Monitors"
msgstr "Όλες Οι Οθόνες"

#: src/prefs/rows.js:194
msgid "Pause on Battery"
msgstr "Παύση λειτουργίας κατά την κατανάλωση μπαταρίας"

#: src/prefs/rows.js:195
msgid "Pause playback when the device is on battery or the battery is low"
msgstr ""
"Παύση της αναπαραγωγής όταν η συσκευή λειτουργεί με μπαταρία ή όταν η "
"μπαταρία είναι χαμηλή"

#: src/prefs/rows.js:196
msgid ""
"\n"
"    <b>Never</b>: Disable this feature.\n"
"    <b>Low Battery</b>: Pause playback when the device is on low battery "
"(below the threshold).\n"
"    <b>Always</b>: Pause playback when the device is on battery.\n"
"    "
msgstr ""
"\n"
"    <b>Ποτέ</b>: Απενεργοποίηση αυτής της λειτουργίας.\n"
"    <b>Χαμηλή μπαταρία</b>: Παύση αναπαραγωγής όταν η μπαταρία της συσκευής είναι χαμηλή (κάτω από το όριο).\n"
"    <b>Πάντα</b>: Παύση αναπαραγωγής όταν η συσκευή λειτουργεί με μπαταρία.\n"
"    "

#: src/prefs/rows.js:204
msgid "Low Battery"
msgstr "ΧαμηλήMπαταρία"

#: src/prefs/rows.js:205
msgid "Always"
msgstr "Πάντα"

#: src/prefs/rows.js:225
msgid "Change Wallpaper Mode"
msgstr "Αλλαγή λειτουργίας ταπετσαρίας"

#: src/prefs/rows.js:226
msgid "Control how to change wallpapers automatically"
msgstr "Έλεγχος του τρόπου αυτόματης αλλαγής ταπετσαριών"

#: src/prefs/rows.js:227
msgid ""
"\n"
"    <b>Sequential:</b> Preserve the directory sequence (descending order).\n"
"    <b>Inverse Sequential:</b> Retrieve wallpapers in the opposite sequence "
"(ascending order).\n"
"    <b>Random:</b> Randomly select wallpapers from the directory.\n"
"    "
msgstr ""
"\n"
"    <b>Διαδοχικά:</b> Διατήρηση της σειράς του καταλόγου (φθίνουσα σειρά).\n"
"    <b>Αντίστροφα διαδοχικά:</b> Ανάκτηση ταπετσαριών με την αντίθετη σειρά (αύξουσα σειρά).\n"
"    <b>Τυχαία:</b> Τυχαία επιλογή ταπετσαριών από τον κατάλογο.\n"
"    "

#: src/prefs/rows.js:234
msgid "Sequential"
msgstr "Διαδοχικά"

#: src/prefs/rows.js:235
msgid "Inverse Sequential"
msgstr "Αντίστροφη Aκολουθία"

#: src/prefs/rows.js:236
msgid "Random"
msgstr "Τυχαία"

