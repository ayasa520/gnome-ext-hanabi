#: src/prefs/rows.js:122
msgid ""
"\n"
"        <b>WPE WebKit</b>: The default backend for web wallpapers.\n"
"        <b>CEF (gstcefsrc)</b>: Experimental Chromium-based backend using "
"GStreamer.\n"
"        "
msgstr ""
"\n"
"        <b>WPE WebKit</b>: De standaard-backend voor webachtergronden.\n"
"        <b>CEF (gstcefsrc)</b>: Experimentele Chromium-gebaseerde backend die GStreamer gebruikt.\n"
"        "

#: src/prefs/rows.js:126
