#: src/prefs/rows.js:68
msgid "Control how wallpaper fits within the monitor"
msgstr "Regel hoe de achtergrond op het scherm past"

#: src/prefs/rows.js:69
msgid ""
"\n"
"    <b>Fill</b>: Stretch the wallpaper to fill the monitor.\n"
"    <b>Contain</b>: Scale the wallpaper to fit the monitor (keep aspect "
"ratio).\n"
"    <b>Cover</b>: Scale the wallpaper to cover the monitor (keep aspect "
"ratio).\n"
"    <b>Scale-down</b>: Scale down the wallpaper to fit the monitor if "
"needed, otherwise keep its original size.\n"
"    "
msgstr ""
"\n"
"    <b>Vullen</b>: Rek de achtergrond uit zodat hij het scherm vult.\n"
"    <b>Inpassen</b>: Schaal de achtergrond zodat hij op het scherm past (beeldverhouding behouden).\n"
"    <b>Bedekken</b>: Schaal de achtergrond zodat hij het scherm bedekt (beeldverhouding behouden).\n"
"    <b>Verkleinen</b>: Verklein de achtergrond indien nodig zodat hij op het scherm past; anders behoudt hij zijn oorspronkelijke grootte.\n"
"    "

#: src/prefs/rows.js:77
msgid "Fill"
