#: src/prefs/rows.js:163
msgid "Pause on Maximize or Fullscreen"
msgstr "Pauzeer op Maximaliseren of Volledig scherm"

#: src/prefs/rows.js:164
msgid "Pause playback when there is maximized or fullscreen window"
msgstr "Pauzeer het afspelen wanneer er een gemaximaliseerd venster of volledig-schermvenster is"

#: src/prefs/rows.js:165
msgid ""
"\n"
"    <b>Never</b>: Disable this feature.\n"
"    <b>Any Monitor</b>: Pause playback when there is maximized or fullscreen "
"window on any monitor.\n"
"    <b>All Monitors</b>: Pause playback when there are maximized or "
"fullscreen windows on all monitors.\n"
"    "
msgstr ""
"\n"
"    <b>Nooit</b>: Schakel deze functie uit.\n"
"    <b>Elk scherm</b>: Pauzeer de weergave wanneer er een gemaximaliseerd of "
"volledig schermvenster op een scherm is.\n"
"    <b>Alle schermen</b>: Pauzeer de weergave wanneer er gemaximaliseerde of "
"volledig schermvensters op alle schermen zijn.\n"
"    "

#: src/prefs/rows.js:172 src/prefs/rows.js:203
msgid "Never"
msgstr "Nooit"

#: src/prefs/rows.js:173
msgid "Any Monitor"
msgstr "Elke Monitor"

#: src/prefs/rows.js:174
msgid "All Monitors"
msgstr "Alle Beeldschermen"

#: src/prefs/rows.js:194
msgid "Pause on Battery"
msgstr "Pauzeer op Batterij"

#: src/prefs/rows.js:195
msgid "Pause playback when the device is on battery or the battery is low"
msgstr "Pauzeer het afspelen wanneer het apparaat op batterij werkt of de batterij bijna leeg is"

#: src/prefs/rows.js:196
msgid ""
"\n"
"    <b>Never</b>: Disable this feature.\n"
"    <b>Low Battery</b>: Pause playback when the device is on low battery "
"(below the threshold).\n"
"    <b>Always</b>: Pause playback when the device is on battery.\n"
"    "
msgstr ""
"\n"
"    <b>Nooit</b>: Schakel deze functie uit.\n"
"    <b>Lage batterij</b>: Pauzeer het afspelen wanneer het apparaat een laag batterijniveau heeft (onder de drempel).\n"
"    <b>Altijd</b>: Pauzeer het afspelen wanneer het apparaat op batterij werkt.\n"
"    "

#: src/prefs/rows.js:204
msgid "Low Battery"
msgstr "Lage batterij"

#: src/prefs/rows.js:205
msgid "Always"
msgstr "Altijd"

#: src/prefs/rows.js:225
msgid "Change Wallpaper Mode"
msgstr "Modus voor achtergrondwissel"

#: src/prefs/rows.js:226
msgid "Control how to change wallpapers automatically"
msgstr "Regel hoe achtergronden automatisch worden gewisseld"

#: src/prefs/rows.js:227
msgid ""
"\n"
"    <b>Sequential:</b> Preserve the directory sequence (descending order).\n"
"    <b>Inverse Sequential:</b> Retrieve wallpapers in the opposite sequence "
"(ascending order).\n"
"    <b>Random:</b> Randomly select wallpapers from the directory.\n"
"    "
msgstr ""
"\n"
"    <b>Opeenvolgend:</b> Behoud de mapvolgorde (aflopende volgorde).\n"
"    <b>Omgekeerd opeenvolgend:</b> Haal achtergronden op in de omgekeerde volgorde (oplopende volgorde).\n"
"    <b>Willekeurig:</b> Kies willekeurig achtergronden uit de map.\n"
"    "

