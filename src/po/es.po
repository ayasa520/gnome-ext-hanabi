#: src/prefs/rows.js:106
msgid "Choose the renderer used for web wallpapers"
msgstr "Elegir el renderizador usado para fondos de pantalla web"

#: src/prefs/rows.js:122
msgid ""
"\n"
"        <b>WPE WebKit</b>: The default backend for web wallpapers.\n"
"        <b>CEF (gstcefsrc)</b>: Experimental Chromium-based backend using "
"GStreamer.\n"
"        "
msgstr ""
"\n"
"        <b>WPE WebKit</b>: Backend predeterminado para fondos de pantalla web.\n"
"        <b>CEF (gstcefsrc)</b>: Backend experimental basado en Chromium que usa GStreamer.\n"
"        "

#: src/prefs/rows.js:126
msgid "<b>WPE WebKit</b>: The default backend for web wallpapers."
msgstr "<b>WPE WebKit</b>: Backend predeterminado para fondos de pantalla web."

#: src/prefs/rows.js:163
msgid "Pause on Maximize or Fullscreen"
msgstr "Pausa en maximizar o pantalla completa"

#: src/prefs/rows.js:164
msgid "Pause playback when there is maximized or fullscreen window"
msgstr ""
"Pausa la reproducción cuando hay una ventana maximizada o a pantalla completa"

#: src/prefs/rows.js:165
msgid ""
"\n"
"    <b>Never</b>: Disable this feature.\n"
"    <b>Any Monitor</b>: Pause playback when there is maximized or fullscreen "
"window on any monitor.\n"
"    <b>All Monitors</b>: Pause playback when there are maximized or "
"fullscreen windows on all monitors.\n"
"    "
msgstr ""
"\n"
"    <b>Nunca</b>: deshabilita esta función.\n"
"    <b>Cualquier monitor</b>: pausa la reproducción cuando haya una ventana "
"maximizada o de pantalla completa en cualquier monitor.\n"
"    <b>Todos los monitores</b>: pausa la reproducción cuando haya ventanas "
"maximizadas o de pantalla completa en todos los monitores.\n"
"    "

#: src/prefs/rows.js:172 src/prefs/rows.js:203
msgid "Never"
msgstr "Nunca"

#: src/prefs/rows.js:173
msgid "Any Monitor"
msgstr "Cualquier monitor"

#: src/prefs/rows.js:174
msgid "All Monitors"
msgstr "Todos los monitores"

#: src/prefs/rows.js:194
msgid "Pause on Battery"
msgstr "Pausa en la batería"

#: src/prefs/rows.js:195
msgid "Pause playback when the device is on battery or the battery is low"
msgstr ""
"Pausa la reproducción cuando el dispositivo está con batería o la batería "
"está baja"

#: src/prefs/rows.js:196
msgid ""
"\n"
"    <b>Never</b>: Disable this feature.\n"
"    <b>Low Battery</b>: Pause playback when the device is on low battery "
"(below the threshold).\n"
"    <b>Always</b>: Pause playback when the device is on battery.\n"
"    "
msgstr ""
"\n"
"    <b>Nunca</b>: deshabilita esta función.\n"
"    <b>Batería baja</b>: pausa la reproducción cuando el dispositivo tiene "
"poca batería (por debajo del umbral).\n"
"    <b>Siempre</b>: pausa la reproducción cuando el dispositivo tiene "
"batería.\n"
"    "

#: src/prefs/rows.js:204
msgid "Low Battery"
msgstr "Batería baja"

#: src/prefs/rows.js:205
msgid "Always"
msgstr "Siempre"

#: src/prefs/rows.js:225
msgid "Change Wallpaper Mode"
msgstr "Cambiar el modo de fondo de pantalla"

#: src/prefs/rows.js:226
msgid "Control how to change wallpapers automatically"
msgstr "Controla cómo cambiar los fondos de pantalla automáticamente"

#: src/prefs/rows.js:227
msgid ""
"\n"
"    <b>Sequential:</b> Preserve the directory sequence (descending order).\n"
"    <b>Inverse Sequential:</b> Retrieve wallpapers in the opposite sequence "
"(ascending order).\n"
"    <b>Random:</b> Randomly select wallpapers from the directory.\n"
"    "
msgstr ""
"\n"
"    <b>Secuencial:</b> Conserve la secuencia de directorios (orden "
"descendente).\n"
"    <b>Secuencial inverso:</b> Recupere fondos de pantalla en la secuencia "
"opuesta (orden ascendente).\n"
"    <b>Aleatorio:</b> Seleccione fondos de pantalla al azar del directorio.\n"
"    "

#: src/prefs/rows.js:234
msgid "Sequential"
msgstr "Secuencial"

#: src/prefs/rows.js:235
msgid "Inverse Sequential"
msgstr "Secuencial inverso"

#: src/prefs/rows.js:236
msgid "Random"
msgstr "Aleatorio"

