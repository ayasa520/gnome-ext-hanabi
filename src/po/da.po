msgstr "Indholde"

#: src/prefs/rows.js:79
msgid "Cover"
msgstr "Dæk"

#: src/prefs/rows.js:80
msgid "Scale-down"
msgstr "Skaler-ned"

#: src/prefs/rows.js:93
