#: src/prefs/rows.js:122
msgid ""
"\n"
"        <b>WPE WebKit</b>: The default backend for web wallpapers.\n"
"        <b>CEF (gstcefsrc)</b>: Experimental Chromium-based backend using "
"GStreamer.\n"
"        "
msgstr ""
"\n"
"        <b>WPE WebKit</b>: бэкенд по умолчанию для веб-обоев.\n"
"        <b>CEF (gstcefsrc)</b>: экспериментальный бэкенд на базе Chromium с использованием GStreamer.\n"
"        "

