#: src/prefs/rows.js:122
msgid ""
"\n"
"        <b>WPE WebKit</b>: The default backend for web wallpapers.\n"
"        <b>CEF (gstcefsrc)</b>: Experimental Chromium-based backend using "
"GStreamer.\n"
"        "
msgstr ""
"\n"
"        <b>WPE WebKit</b> : backend par défaut pour les fonds d’écran web.\n"
"        <b>CEF (gstcefsrc)</b> : backend expérimental basé sur Chromium utilisant GStreamer.\n"
"        "

#: src/prefs/rows.js:126
msgid "<b>WPE WebKit</b>: The default backend for web wallpapers."
msgstr "<b>WPE WebKit</b> : backend par défaut pour les fonds d’écran web."

#: src/prefs/rows.js:163
msgid "Pause on Maximize or Fullscreen"
msgstr "Pause si maximisée ou en plein écran"

#: src/prefs/rows.js:164
msgid "Pause playback when there is maximized or fullscreen window"
msgstr ""
"Mettre en pause la lecture lorsqu'il y a une fenêtre maximisée ou en plein "
"écran"

#: src/prefs/rows.js:165
msgid ""
"\n"
"    <b>Never</b>: Disable this feature.\n"
"    <b>Any Monitor</b>: Pause playback when there is maximized or fullscreen "
"window on any monitor.\n"
"    <b>All Monitors</b>: Pause playback when there are maximized or "
"fullscreen windows on all monitors.\n"
"    "
msgstr ""
"\n"
"    <b>Jamais</b>: Désactive cette fonctionnalité.\n"
"    <b>N'importe quel écran</b>: Mettre en pause la lecture lorsqu'il y a "
"une fenêtre maximisée ou en plein écran sur n'importe quel écran. fenêtre "
"sur tout les écrans\n"
"    <b>Tous les écrans</b>: Mettre en pause la lecture lorsqu'il y a des "
"fenêtres maximisées ou en plein écran sur tous les écrans\n"
"    "

#: src/prefs/rows.js:172 src/prefs/rows.js:203
msgid "Never"
msgstr "Jamais"

#: src/prefs/rows.js:173
msgid "Any Monitor"
msgstr "N'importe quel écran"

#: src/prefs/rows.js:174
msgid "All Monitors"
msgstr "Tout les écrans"

#: src/prefs/rows.js:194
msgid "Pause on Battery"
msgstr "Pause sur batterie"

#: src/prefs/rows.js:195
msgid "Pause playback when the device is on battery or the battery is low"
msgstr ""
"Arrêter la lecture lorsque l'appareil est sur batterie ou lorsque la "
"batterie est faible"

#: src/prefs/rows.js:196
msgid ""
"\n"
"    <b>Never</b>: Disable this feature.\n"
"    <b>Low Battery</b>: Pause playback when the device is on low battery "
"(below the threshold).\n"
"    <b>Always</b>: Pause playback when the device is on battery.\n"
"    "
msgstr ""
"\n"
"    <b>Jamais</b>: Désactive cette fonctionnalité.\n"
"    <b>Batterie faible</b>: Arrête la lecture lorsque la batterie est "
"faible. (en dessous du seuil).\n"
"    <b>Toujours</b>: Arrête la lecture lorsque l'appareil est sur batterie.\n"
"    "

#: src/prefs/rows.js:204
msgid "Low Battery"
msgstr "Batterie faible"

#: src/prefs/rows.js:205
msgid "Always"
msgstr "Toujours"

#: src/prefs/rows.js:225
msgid "Change Wallpaper Mode"
msgstr "Modifier le mode de fond d'écran"

#: src/prefs/rows.js:226
msgid "Control how to change wallpapers automatically"
msgstr "Contrôle comment changer le fond d'écran automatiquement"

#: src/prefs/rows.js:227
msgid ""
"\n"
"    <b>Sequential:</b> Preserve the directory sequence (descending order).\n"
"    <b>Inverse Sequential:</b> Retrieve wallpapers in the opposite sequence "
"(ascending order).\n"
"    <b>Random:</b> Randomly select wallpapers from the directory.\n"
"    "
msgstr ""
"\n"
"    <b>Séquentiel:</b> Préserve la séquence du répertoire (ordre "
"descendant).\n"
"    <b>Séquentiel inversé:</b> Affiche les fonds d'écran dans l'ordre "
"inversé (ordre ascendant).\n"
"    <b>Aléatoire:</b> Affiche un fond d'écran aléatoire à partir du "
"répertoire.\n"
"    "

#: src/prefs/rows.js:234
msgid "Sequential"
msgstr "Séquentiel"

#: src/prefs/rows.js:235
msgid "Inverse Sequential"
msgstr "Séquentiel inversé"

#: src/prefs/rows.js:236
msgid "Random"
msgstr "Aléatoire"

