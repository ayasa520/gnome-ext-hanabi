#: src/prefs/rows.js:68
msgid "Control how wallpaper fits within the monitor"
msgstr "Gérer l'affichage du fond d'écran sur l'écran"

#: src/prefs/rows.js:69
msgid ""
"\n"
"    <b>Fill</b>: Stretch the wallpaper to fill the monitor.\n"
"    <b>Contain</b>: Scale the wallpaper to fit the monitor (keep aspect "
"ratio).\n"
"    <b>Cover</b>: Scale the wallpaper to cover the monitor (keep aspect "
"ratio).\n"
"    <b>Scale-down</b>: Scale down the wallpaper to fit the monitor if "
"needed, otherwise keep its original size.\n"
"    "
msgstr ""
"\n"
"    <b>Étirer</b>: Étirer le fond d'écran pour qu'il remplisse l'écran.\n"
"<b>Contenir</b>: Met à l'échelle le fond d'écran pour correspondre à l'écran "
"(garde le ratio).\n"
"<b>Couvrir</b>: Met à l'échelle le fond d'écran pour remplir l'écran (garde "
"le ration).\n"
"<b>Mise à l'échelle</b>: Redimensionne le fond d'écran pour correspondre à  "
"l'écran si nécessaire, sinon conserve la taille originale.\n"
"    "

#: src/prefs/rows.js:77
msgid "Fill"
msgstr "Remplir"

#: src/prefs/rows.js:78
msgid "Contain"
msgstr "Adapter"

#: src/prefs/rows.js:79
msgid "Cover"
msgstr "Couvrir"

#: src/prefs/rows.js:80
msgid "Scale-down"
msgstr "Mise à l'échelle"

#: src/prefs/rows.js:93
msgid "This feature requires Gtk 4.8 or above"
msgstr ""
"Cette fonctionnalité nécessite la version 4.8 de Gtk ou une version "
"ultérieure."

#: src/prefs/rows.js:105
msgid "Web Backend"
