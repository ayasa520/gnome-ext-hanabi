#: src/prefs/rows.js:68
msgid "Control how wallpaper fits within the monitor"
msgstr "Regi kiel ekranfono adaptiĝas ene de la ekrano"

#: src/prefs/rows.js:69
msgid ""
"\n"
"    <b>Fill</b>: Stretch the wallpaper to fill the monitor.\n"
"    <b>Contain</b>: Scale the wallpaper to fit the monitor (keep aspect "
"ratio).\n"
"    <b>Cover</b>: Scale the wallpaper to cover the monitor (keep aspect "
"ratio).\n"
"    <b>Scale-down</b>: Scale down the wallpaper to fit the monitor if "
"needed, otherwise keep its original size.\n"
"    "
msgstr ""
"\n"
"    <b>Plenigi</b>: Streĉi la ekranfonon por plenigi la ekranon.\n"
"    <b>Enteni</b>: Skali la ekranfonon por adapti ĝin al la ekrano (konservi proporciojn).\n"
"    <b>Kovri</b>: Skali la ekranfonon por kovri la ekranon (konservi proporciojn).\n"
"    <b>Malgrandigi</b>: Malgrandigi la ekranfonon por adapti ĝin al la ekrano se necese; alie konservi ĝian originan grandecon.\n"
"    "

#: src/prefs/rows.js:77
msgid "Fill"
