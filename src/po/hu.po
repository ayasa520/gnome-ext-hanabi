#: src/prefs/rows.js:69
msgid ""
"\n"
"    <b>Fill</b>: Stretch the wallpaper to fill the monitor.\n"
"    <b>Contain</b>: Scale the wallpaper to fit the monitor (keep aspect "
"ratio).\n"
"    <b>Cover</b>: Scale the wallpaper to cover the monitor (keep aspect "
"ratio).\n"
"    <b>Scale-down</b>: Scale down the wallpaper to fit the monitor if "
"needed, otherwise keep its original size.\n"
"    "
msgstr ""
"\n"
"    <b>Kitöltés</b>: A háttérkép képernyőhöz nyújtással.\n"
"    <b>Teljes háttérkép</b>: Háttérkép méretezése, hogy elférjen a képernyőn "
"(képarány megtartása).\n"
"    <b>Teljes képernyő</b>: Háttérkép méretezése, hogy kitöltse a képernyőt "
"(képarány megtartása).\n"
"    <b>Kicsinyítés</b>: Kicsinyítse a képet, hogy elférjen a képernyőn, ha "
"szükséges, amúgy tartsa meg az erdeti méretet.\n"
"    "

#: src/prefs/rows.js:77
msgid "Fill"
msgstr "Kitöltés"

#: src/prefs/rows.js:78
msgid "Contain"
msgstr "Teljes háttérkép"

#: src/prefs/rows.js:79
msgid "Cover"
msgstr "Teljes képernyő"

#: src/prefs/rows.js:80
msgid "Scale-down"
msgstr "Kicsinyítés"

#: src/prefs/rows.js:93
msgid "This feature requires Gtk 4.8 or above"
msgstr "Ehhez a funkcióhoz Gtk 4.8 vagy újabb szükséges"

#: src/prefs/rows.js:105
msgid "Web Backend"
msgstr "Webes háttérrendszer"

#: src/prefs/rows.js:106
msgid "Choose the renderer used for web wallpapers"
msgstr "Válassza ki a webes háttérképekhez használt megjelenítőt"

#: src/prefs/rows.js:122
msgid ""
"\n"
"        <b>WPE WebKit</b>: The default backend for web wallpapers.\n"
"        <b>CEF (gstcefsrc)</b>: Experimental Chromium-based backend using "
"GStreamer.\n"
"        "
msgstr ""
"\n"
"        <b>WPE WebKit</b>: A webes háttérképek alapértelmezett háttérrendszere.\n"
"        <b>CEF (gstcefsrc)</b>: Kísérleti, Chromium-alapú háttérrendszer GStreamer használatával.\n"
"        "

#: src/prefs/rows.js:126
msgid "<b>WPE WebKit</b>: The default backend for web wallpapers."
msgstr "<b>WPE WebKit</b>: A webes háttérképek alapértelmezett háttérrendszere."

#: src/prefs/rows.js:163
msgid "Pause on Maximize or Fullscreen"
msgstr "Szüneteltetés teljes méret vagy teljes képernyő esetén"

#: src/prefs/rows.js:164
msgid "Pause playback when there is maximized or fullscreen window"
msgstr ""
"Lejátszás szüneteltetése, ha egy ablak teljes méret vagy teljes képernyő "
"módban van"

#: src/prefs/rows.js:165
msgid ""
"\n"
"    <b>Never</b>: Disable this feature.\n"
"    <b>Any Monitor</b>: Pause playback when there is maximized or fullscreen "
"window on any monitor.\n"
"    <b>All Monitors</b>: Pause playback when there are maximized or "
"fullscreen windows on all monitors.\n"
"    "
msgstr ""
"\n"
"    <b>Soha</b>: Funkció kikapcsolása.\n"
"    <b>Bármely képernyő</b>: Lejátszás szüneteltetése teljes méret vagy "
"teljes képernyő esetén bármely monitoron.\n"
"    <b>Összes képernyő</b>: Lejátszás szüneteltetése teljes méret vagy "
"teljes képernyő esetén az összes monitoron.\n"
"    "

#: src/prefs/rows.js:172 src/prefs/rows.js:203
msgid "Never"
msgstr "Soha"

#: src/prefs/rows.js:173
msgid "Any Monitor"
msgstr "Bármely képernyő"

#: src/prefs/rows.js:174
msgid "All Monitors"
msgstr "Összes képernyő"

#: src/prefs/rows.js:194
msgid "Pause on Battery"
msgstr "Szüneteltetés akkumulátor használat esetén"

#: src/prefs/rows.js:195
msgid "Pause playback when the device is on battery or the battery is low"
msgstr ""
"Lejátszás szüneteltetése, ha az eszköz akkumulátort használ, vagy az "
"akkumulátorszint alacsony"

#: src/prefs/rows.js:196
msgid ""
"\n"
"    <b>Never</b>: Disable this feature.\n"
"    <b>Low Battery</b>: Pause playback when the device is on low battery "
"(below the threshold).\n"
"    <b>Always</b>: Pause playback when the device is on battery.\n"
"    "
msgstr ""
"\n"
"    <b>Soha</b>: Funkció kikapcsolása.\n"
"    <b>Alacsony akkumulátorszint</b>: Lejátszás szüneteltetése, ha a "
"készülék alacsony akkumulátorszinten van (értékhatár alatt).\n"
"    <b>Mindig</b>: Lejátszás szüneteltetése, ha a készülék akkumulátorról "
"üzemel.\n"
"    "

#: src/prefs/rows.js:204
msgid "Low Battery"
msgstr "Alacsony akkumulátorszint"

#: src/prefs/rows.js:205
msgid "Always"
msgstr "Mindig"

#: src/prefs/rows.js:225
msgid "Change Wallpaper Mode"
msgstr "Háttérkép módjának változtatása"

#: src/prefs/rows.js:226
msgid "Control how to change wallpapers automatically"
msgstr "Szabályozza, hogy hogyan változzank a háttérképek automatikusan"

#: src/prefs/rows.js:227
msgid ""
"\n"
"    <b>Sequential:</b> Preserve the directory sequence (descending order).\n"
"    <b>Inverse Sequential:</b> Retrieve wallpapers in the opposite sequence "
"(ascending order).\n"
"    <b>Random:</b> Randomly select wallpapers from the directory.\n"
"    "
msgstr ""
"\n"
"    <b>Csökkenő:</b> Könyvtár sorrendjének megtartása (csökkenő sorrend).\n"
"    <b>Növekvő:</b> Könyvtár sorrendjének megfordítása (növekvő sorrend).\n"
"    <b>Véletlenszerű:</b> Háttérkép választása véletlenszerűen a "
"könyvtárból.\n"
"    "

#: src/prefs/rows.js:234
msgid "Sequential"
msgstr "Csökkenő"

#: src/prefs/rows.js:235
msgid "Inverse Sequential"
msgstr "Növekvő"

#: src/prefs/rows.js:236
msgid "Random"
msgstr "Véletlenszerű"

