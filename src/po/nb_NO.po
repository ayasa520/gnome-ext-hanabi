#: src/prefs/rows.js:122
msgid ""
"\n"
"        <b>WPE WebKit</b>: The default backend for web wallpapers.\n"
"        <b>CEF (gstcefsrc)</b>: Experimental Chromium-based backend using "
"GStreamer.\n"
"        "
msgstr ""
"\n"
"        <b>WPE WebKit</b>: Standard-backenden for webbakgrunner.\n"
"        <b>CEF (gstcefsrc)</b>: Eksperimentell Chromium-basert backend som bruker GStreamer.\n"
"        "

#: src/prefs/rows.js:126
msgid "<b>WPE WebKit</b>: The default backend for web wallpapers."
msgstr "<b>WPE WebKit</b>: Standard-backenden for webbakgrunner."

#: src/prefs/rows.js:163
msgid "Pause on Maximize or Fullscreen"
msgstr "Pause ved maksimering eller fullskjerm"

#: src/prefs/rows.js:164
msgid "Pause playback when there is maximized or fullscreen window"
msgstr "Sett avspillingen på pause når det finnes et maksimert vindu eller et fullskjermsvindu"

#: src/prefs/rows.js:165
msgid ""
"\n"
"    <b>Never</b>: Disable this feature.\n"
"    <b>Any Monitor</b>: Pause playback when there is maximized or fullscreen "
"window on any monitor.\n"
"    <b>All Monitors</b>: Pause playback when there are maximized or "
"fullscreen windows on all monitors.\n"
"    "
msgstr ""
"\n"
"    <b>Aldri</b>: Slå av denne funksjonen.\n"
"    <b>Hvilken som helst skjerm</b>: Sett avspillingen på pause når det finnes et maksimert vindu eller et fullskjermsvindu på en hvilken som helst skjerm.\n"
"    <b>Alle skjermer</b>: Sett avspillingen på pause når det finnes maksimerte vinduer eller fullskjermsvinduer på alle skjermer.\n"
"    "

#: src/prefs/rows.js:172 src/prefs/rows.js:203
msgid "Never"
msgstr "Aldri"

#: src/prefs/rows.js:173
msgid "Any Monitor"
msgstr "Hvilken som helst skjerm"

#: src/prefs/rows.js:174
msgid "All Monitors"
msgstr "Alle skjermer"

#: src/prefs/rows.js:194
msgid "Pause on Battery"
msgstr "Pause på batteri"

#: src/prefs/rows.js:195
msgid "Pause playback when the device is on battery or the battery is low"
msgstr "Sett avspillingen på pause når enheten går på batteri eller batterinivået er lavt"

#: src/prefs/rows.js:196
msgid ""
"\n"
"    <b>Never</b>: Disable this feature.\n"
"    <b>Low Battery</b>: Pause playback when the device is on low battery "
"(below the threshold).\n"
"    <b>Always</b>: Pause playback when the device is on battery.\n"
"    "
msgstr ""
"\n"
"    <b>Aldri</b>: Slå av denne funksjonen.\n"
"    <b>Lavt batteri</b>: Sett avspillingen på pause når enheten har lavt batterinivå (under grensen).\n"
"    <b>Alltid</b>: Sett avspillingen på pause når enheten går på batteri.\n"
"    "

#: src/prefs/rows.js:204
msgid "Low Battery"
msgstr "Lavt batteri"

#: src/prefs/rows.js:205
msgid "Always"
msgstr "Alltid"

#: src/prefs/rows.js:225
msgid "Change Wallpaper Mode"
msgstr "Modus for bakgrunnsbytte"

#: src/prefs/rows.js:226
msgid "Control how to change wallpapers automatically"
msgstr "Styr hvordan bakgrunner byttes automatisk"

#: src/prefs/rows.js:227
msgid ""
"\n"
"    <b>Sequential:</b> Preserve the directory sequence (descending order).\n"
"    <b>Inverse Sequential:</b> Retrieve wallpapers in the opposite sequence "
"(ascending order).\n"
"    <b>Random:</b> Randomly select wallpapers from the directory.\n"
"    "
msgstr ""
"\n"
"    <b>Sekvensielt:</b> Bevar mapperekkefølgen (synkende rekkefølge).\n"
"    <b>Omvendt sekvensielt:</b> Hent bakgrunner i motsatt rekkefølge (stigende rekkefølge).\n"
"    <b>Tilfeldig:</b> Velg bakgrunner tilfeldig fra mappen.\n"
"    "

#: src/prefs/rows.js:234
msgid "Sequential"
msgstr "Sekvensielt"

#: src/prefs/rows.js:235
msgid "Inverse Sequential"
msgstr "Omvendt sekvensielt"

#: src/prefs/rows.js:236
msgid "Random"
msgstr "Tilfeldig"

