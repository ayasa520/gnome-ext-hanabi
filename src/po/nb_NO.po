#: src/prefs/rows.js:68
msgid "Control how wallpaper fits within the monitor"
msgstr "Kontroller hvordan bakgrunnsbildet passer på skjermen"

#: src/prefs/rows.js:69
msgid ""
"\n"
"    <b>Fill</b>: Stretch the wallpaper to fill the monitor.\n"
"    <b>Contain</b>: Scale the wallpaper to fit the monitor (keep aspect "
"ratio).\n"
"    <b>Cover</b>: Scale the wallpaper to cover the monitor (keep aspect "
"ratio).\n"
"    <b>Scale-down</b>: Scale down the wallpaper to fit the monitor if "
"needed, otherwise keep its original size.\n"
"    "
msgstr ""
"\n"
"    <b>Fyll</b>: Strekk bakgrunnen slik at den fyller skjermen.\n"
"    <b>Tilpass</b>: Skaler bakgrunnen slik at den passer på skjermen (behold størrelsesforholdet).\n"
"    <b>Dekk</b>: Skaler bakgrunnen slik at den dekker skjermen (behold størrelsesforholdet).\n"
"    <b>Skaler ned</b>: Skaler ned bakgrunnen slik at den passer på skjermen ved behov; ellers beholdes den opprinnelige størrelsen.\n"
"    "

#: src/prefs/rows.js:77
msgid "Fill"
msgstr "Fyll"

#: src/prefs/rows.js:78
