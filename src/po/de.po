#: src/prefs/rows.js:67
msgid "Fit Mode"
msgstr "Anpassungsmodus"

#: src/prefs/rows.js:68
msgid "Control how wallpaper fits within the monitor"
msgstr "Steuere, wie das Hintergrundbild in den Monitor passt"

#: src/prefs/rows.js:69
msgid ""
"\n"
"    <b>Fill</b>: Stretch the wallpaper to fill the monitor.\n"
"    <b>Contain</b>: Scale the wallpaper to fit the monitor (keep aspect "
"ratio).\n"
"    <b>Cover</b>: Scale the wallpaper to cover the monitor (keep aspect "
"ratio).\n"
"    <b>Scale-down</b>: Scale down the wallpaper to fit the monitor if "
"needed, otherwise keep its original size.\n"
"    "
msgstr ""
"\n"
"    <b>Ausfüllen</b>: Streckt das Hintergrundbild, um den Monitor "
"auszufüllen.\n"
"    <b>Anpassen</b>: Skaliert das Hintergrundbild, dass es auf den Monitor "
"passt (Seitenverhältnis beibehalten). \n"
"    <b>Bedecken</b>: Das Hintergrundbild so skalieren, dass er den Monitor "
"bedeckt (Seitenverhältnis beibehalten).\n"
"    <b>Verkleinern</b>: Verkleinert bei bedarf das Hintergrundbild, um es an "
"den Monitor anzupassen.\n"
"    "

#: src/prefs/rows.js:77
msgid "Fill"
msgstr "Ausfüllen"

#: src/prefs/rows.js:78
msgid "Contain"
msgstr "Anpassen"

#: src/prefs/rows.js:79
msgid "Cover"
msgstr "Bedecken"

#: src/prefs/rows.js:80
msgid "Scale-down"
msgstr "Verkleinern"

#: src/prefs/rows.js:93
msgid "This feature requires Gtk 4.8 or above"
msgstr "Diese Funktion benötigt Gtk 4.8 oder höher"

#: src/prefs/rows.js:105
msgid "Web Backend"
