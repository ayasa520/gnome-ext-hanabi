#: src/prefs/rows.js:68
msgid "Control how wallpaper fits within the monitor"
msgstr "Upravljaj načinom prilagodbe pozadine monitoru"

#: src/prefs/rows.js:69
msgid ""
"\n"
"    <b>Fill</b>: Stretch the wallpaper to fill the monitor.\n"
"    <b>Contain</b>: Scale the wallpaper to fit the monitor (keep aspect "
"ratio).\n"
"    <b>Cover</b>: Scale the wallpaper to cover the monitor (keep aspect "
"ratio).\n"
"    <b>Scale-down</b>: Scale down the wallpaper to fit the monitor if "
"needed, otherwise keep its original size.\n"
"    "
msgstr ""
"\n"
"    <b>Ispuni</b>: Razvuci pozadinu da ispuni monitor.\n"
"    <b>Prilagodi</b>: Skaliraj pozadinu da stane na monitor (zadrži omjer slike).\n"
"    <b>Prekrij</b>: Skaliraj pozadinu da prekrije monitor (zadrži omjer slike).\n"
"    <b>Smanji</b>: Smanji pozadinu da stane na monitor ako je potrebno; inače zadrži izvornu veličinu.\n"
"    "

#: src/prefs/rows.js:77
msgid "Fill"
msgstr "Ispuni"

#: src/prefs/rows.js:78
msgid "Contain"
msgstr "Prilagodi"

#: src/prefs/rows.js:79
msgid "Cover"
msgstr "Prekrij"

#: src/prefs/rows.js:80
msgid "Scale-down"
msgstr "Smanji"

#: src/prefs/rows.js:93
msgid "This feature requires Gtk 4.8 or above"
msgstr "Ova značajka zahtijeva Gtk 4.8 ili noviji"

#: src/prefs/rows.js:105
msgid "Web Backend"
msgstr "Web pozadinski sustav"

#: src/prefs/rows.js:106
msgid "Choose the renderer used for web wallpapers"
msgstr "Odaberi renderer koji se koristi za web pozadine"

#: src/prefs/rows.js:122
msgid ""
"\n"
"        <b>WPE WebKit</b>: The default backend for web wallpapers.\n"
"        <b>CEF (gstcefsrc)</b>: Experimental Chromium-based backend using "
"GStreamer.\n"
"        "
msgstr ""
"\n"
"        <b>WPE WebKit</b>: Zadani pozadinski sustav za web pozadine.\n"
"        <b>CEF (gstcefsrc)</b>: Eksperimentalni pozadinski sustav temeljen na Chromiumu koji koristi GStreamer.\n"
"        "

#: src/prefs/rows.js:126
msgid "<b>WPE WebKit</b>: The default backend for web wallpapers."
msgstr "<b>WPE WebKit</b>: Zadani pozadinski sustav za web pozadine."

#: src/prefs/rows.js:163
msgid "Pause on Maximize or Fullscreen"
msgstr "Zaustavi Video u Fullscreen-u"

#: src/prefs/rows.js:164
msgid "Pause playback when there is maximized or fullscreen window"
msgstr "Pauziraj reprodukciju kada postoji maksimizirani prozor ili prozor preko cijelog zaslona"

#: src/prefs/rows.js:165
msgid ""
"\n"
"    <b>Never</b>: Disable this feature.\n"
"    <b>Any Monitor</b>: Pause playback when there is maximized or fullscreen "
"window on any monitor.\n"
"    <b>All Monitors</b>: Pause playback when there are maximized or "
"fullscreen windows on all monitors.\n"
"    "
msgstr ""
"\n"
"    <b>Nikad</b>: Isključi ovu funkcionalnost.\n"
"    <b>Jedan Monitor</b>: Zaustavi video kada je na jednom od monitora "
"maksimiziran prozor preko cijelog ekrana.\n"
"    <b>Svi Monitori</b>: Zaustavi video kada su na svim monitorima "
"maksimiziran prozori preko cijelog ekrana.\n"
"    "

#: src/prefs/rows.js:172 src/prefs/rows.js:203
msgid "Never"
msgstr "Nikad"

#: src/prefs/rows.js:173
msgid "Any Monitor"
msgstr "Bilo Koji Monitor"

#: src/prefs/rows.js:174
msgid "All Monitors"
msgstr "Svi monitori"

#: src/prefs/rows.js:194
msgid "Pause on Battery"
msgstr "Zaustavi Video dok na Bateriji."

#: src/prefs/rows.js:195
msgid "Pause playback when the device is on battery or the battery is low"
msgstr "Pauziraj reprodukciju kada uređaj radi na bateriji ili je baterija niska"

#: src/prefs/rows.js:196
msgid ""
"\n"
"    <b>Never</b>: Disable this feature.\n"
"    <b>Low Battery</b>: Pause playback when the device is on low battery "
"(below the threshold).\n"
"    <b>Always</b>: Pause playback when the device is on battery.\n"
"    "
msgstr ""
"\n"
"    <b>Nikad</b>: Onemogući ovu značajku.\n"
"    <b>Niska baterija</b>: Pauziraj reprodukciju kada je baterija uređaja niska (ispod praga).\n"
"    <b>Uvijek</b>: Pauziraj reprodukciju kada uređaj radi na bateriji.\n"
"    "

#: src/prefs/rows.js:204
msgid "Low Battery"
msgstr "Niska Baterija"

#: src/prefs/rows.js:205
msgid "Always"
msgstr "Uvijek"

#: src/prefs/rows.js:225
msgid "Change Wallpaper Mode"
msgstr "Način promjene pozadine"

#: src/prefs/rows.js:226
msgid "Control how to change wallpapers automatically"
msgstr "Upravljaj načinom automatske promjene pozadina"

#: src/prefs/rows.js:227
msgid ""
"\n"
"    <b>Sequential:</b> Preserve the directory sequence (descending order).\n"
"    <b>Inverse Sequential:</b> Retrieve wallpapers in the opposite sequence "
"(ascending order).\n"
"    <b>Random:</b> Randomly select wallpapers from the directory.\n"
"    "
msgstr ""
"\n"
"    <b>Slijedno:</b> Zadrži redoslijed direktorija (silazni redoslijed).\n"
"    <b>Obrnuto slijedno:</b> Dohvati pozadine u suprotnom redoslijedu (uzlazni redoslijed).\n"
"    <b>Nasumično:</b> Nasumično odaberi pozadine iz direktorija.\n"
"    "

#: src/prefs/rows.js:234
