msgid "Pause"
msgstr "இடைநிறுத்தம்"

#: src/shell/ui/panelMenu.js:72 src/shell/ui/panelMenu.js:77
msgid "Play"
msgstr "விளையாடுங்கள்"

#: src/shell/ui/panelMenu.js:117 src/shell/ui/panelMenu.js:123
msgid "Unmute Audio"
msgstr "இயக்க ஆடியோ"

#: src/shell/ui/panelMenu.js:143
