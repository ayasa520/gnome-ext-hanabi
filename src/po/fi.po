#: src/prefs/rows.js:68
msgid "Control how wallpaper fits within the monitor"
msgstr "Hallinnoi miten taustakuva asettuu näytölle"

#: src/prefs/rows.js:69
msgid ""
"\n"
"    <b>Fill</b>: Stretch the wallpaper to fill the monitor.\n"
"    <b>Contain</b>: Scale the wallpaper to fit the monitor (keep aspect "
"ratio).\n"
"    <b>Cover</b>: Scale the wallpaper to cover the monitor (keep aspect "
"ratio).\n"
"    <b>Scale-down</b>: Scale down the wallpaper to fit the monitor if "
"needed, otherwise keep its original size.\n"
"    "
msgstr ""
"\n"
"    <b>Täytä</b>: Venytä taustakuva näytön täyttämiseksi.\n"
"    <b>Sovita</b>: Skaalaa taustakuva sopivaksi näyttöön (säilytä "
"kuvasuhde).\n"
"    <b>Peitä</b>: Skaalaa taustakuva peittääksesi näytön (säilytä "
"kuvasuhde).\n"
"    <b>Suhteuta</b>: Pienennä taustakuvaa näytölle sopivaksi tarvittaessa, "
"mutta muutoin säilytä alkuperäinen koko.\n"
"    "

#: src/prefs/rows.js:77
msgid "Fill"
msgstr "Täytä"

#: src/prefs/rows.js:78
msgid "Contain"
msgstr "Sisällytä"

#: src/prefs/rows.js:79
msgid "Cover"
msgstr "Peitä"

#: src/prefs/rows.js:80
msgid "Scale-down"
msgstr "Pienennä mittakaavassa"

#: src/prefs/rows.js:93
msgid "This feature requires Gtk 4.8 or above"
msgstr "Tämä ominaisuus vaatii Gtk julkaisun 4.8 tai uudemman"

#: src/prefs/rows.js:105
msgid "Web Backend"
msgstr "Web-taustajärjestelmä"

#: src/prefs/rows.js:106
msgid "Choose the renderer used for web wallpapers"
msgstr "Valitse verkkotaustakuvissa käytettävä renderöijä"

#: src/prefs/rows.js:122
msgid ""
"\n"
"        <b>WPE WebKit</b>: The default backend for web wallpapers.\n"
"        <b>CEF (gstcefsrc)</b>: Experimental Chromium-based backend using "
"GStreamer.\n"
"        "
msgstr ""
"\n"
"        <b>WPE WebKit</b>: Verkkotaustakuvien oletustaustajärjestelmä.\n"
"        <b>CEF (gstcefsrc)</b>: Kokeellinen Chromium-pohjainen GStreameria käyttävä taustajärjestelmä.\n"
"        "

#: src/prefs/rows.js:126
msgid "<b>WPE WebKit</b>: The default backend for web wallpapers."
msgstr "<b>WPE WebKit</b>: Verkkotaustakuvien oletustaustajärjestelmä."

#: src/prefs/rows.js:163
msgid "Pause on Maximize or Fullscreen"
msgstr "Tauota enimmäisikkunoinnin tai kokoruututilan kohdalla"

#: src/prefs/rows.js:164
msgid "Pause playback when there is maximized or fullscreen window"
msgstr "Tauota toisto kun ikkuna suurennetaan tai asetetaan kokoruututilaan"

#: src/prefs/rows.js:165
msgid ""
"\n"
"    <b>Never</b>: Disable this feature.\n"
"    <b>Any Monitor</b>: Pause playback when there is maximized or fullscreen "
"window on any monitor.\n"
"    <b>All Monitors</b>: Pause playback when there are maximized or "
"fullscreen windows on all monitors.\n"
"    "
msgstr ""
"\n"
"    <b>Älä milloinkaan</b>: Kytke pois tätä ominaisuutta.\n"
"    <b>Mikä tahansa näyttö</b>: Tauota toisto kun mille tahansa näytölle "
"asetetaan suurennettu tai kokoruutuikkuna.\n"
"    <b>Kaikki näytöt</b>: Tauota toisto mikäli kaikilla näytöillä on "
"suurennettuja tai kokoruudun ikkunoita.\n"
"    "

#: src/prefs/rows.js:172 src/prefs/rows.js:203
msgid "Never"
msgstr "Ei koskaan"

#: src/prefs/rows.js:173
msgid "Any Monitor"
msgstr "Mikä tahansa näyttö"

#: src/prefs/rows.js:174
msgid "All Monitors"
msgstr "Kaikki näytöt"

#: src/prefs/rows.js:194
msgid "Pause on Battery"
msgstr "Tauota akkuvirralla"

#: src/prefs/rows.js:195
msgid "Pause playback when the device is on battery or the battery is low"
msgstr ""
"Tauota toisto laitteen ollessa akkuvirran varassa tai akun varaus on vähissä"

#: src/prefs/rows.js:196
msgid ""
"\n"
"    <b>Never</b>: Disable this feature.\n"
"    <b>Low Battery</b>: Pause playback when the device is on low battery "
"(below the threshold).\n"
"    <b>Always</b>: Pause playback when the device is on battery.\n"
"    "
msgstr ""
"\n"
"    <b>Älä milloinkaan</b>: Kytke pois tätä ominaisuutta.\n"
"    <b>Vähäinen akunlataus</b>: Tauota toisto kun laitteen akku on vähissä "
"(määritetyn kynnyksen alapuolella).\n"
"    <b>Aina</b>: Tauota toisto laitteen ollessa akkuvirran varassa.\n"
"    "

#: src/prefs/rows.js:204
msgid "Low Battery"
msgstr "Akku vähissä"

#: src/prefs/rows.js:205
msgid "Always"
msgstr "Aina"

#: src/prefs/rows.js:225
msgid "Change Wallpaper Mode"
msgstr "Vaihda taustakuvatila"

#: src/prefs/rows.js:226
msgid "Control how to change wallpapers automatically"
msgstr "Hallinnoi taustakuvien automaattista vaihtoa"

#: src/prefs/rows.js:227
msgid ""
"\n"
"    <b>Sequential:</b> Preserve the directory sequence (descending order).\n"
"    <b>Inverse Sequential:</b> Retrieve wallpapers in the opposite sequence "
"(ascending order).\n"
"    <b>Random:</b> Randomly select wallpapers from the directory.\n"
"    "
msgstr ""
"\n"
"    <b>Järjestyksellinen:</b> Säilytä hakemistojärjestys (laskevasti).\n"
"    <b>Käänteinen järjestys:</b> Hae taustakuvia vastakkaisessa "
"järjestyksessä (nousevasti).\n"
"    <b>satunnainen:</b> Valitse taustakuvia hakemistosta satunnaisesti.\n"
"    "

#: src/prefs/rows.js:234
msgid "Sequential"
msgstr "Järjestyksellinen"

#: src/prefs/rows.js:235
msgid "Inverse Sequential"
msgstr "Käänteinen järjestys"

#: src/prefs/rows.js:236
msgid "Random"
msgstr "Satunnainen"

